{
  "name": "parttimepro-backend",
  "version": "1.0.0",
  "description": "Backend API for PartTimePro - Professional Job Portal (Python + FastAPI)",
  "main": "app/main.py",
  "scripts": {
    "start": "python -m uvicorn app.main:app --reload",
    "dev": "python -m uvicorn app.main:app --reload --port 8000",
    "prod": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "test": "pytest",
    "format": "black .",
    "lint": "pylint app/",
    "migrate": "alembic upgrade head",
    "makemigrations": "alembic revision --autogenerate"
  },
  "keywords": [
    "job-portal",
    "part-time",
    "fastapi",
    "sqlalchemy",
    "sqlite",
    "python"
  ],
  "author": "",
  "license": "MIT",
  "runtime": "python3.9+"
}
